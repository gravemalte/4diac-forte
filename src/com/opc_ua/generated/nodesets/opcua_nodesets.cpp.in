#include "com/opc_ua/opcua_local_handler.h"

extern "C" {
${includes}
}

bool COPC_UA_Local_Handler::initializeNodesets(UA_Server &paUaServer [[maybe_unused]]){
#define ENTRY(ua_nodeset) \
  if (UA_STATUSCODE_GOOD != ua_namespace_${ua_nodeset}(&paUaServer)) return false;
  ${entries}
#undef ENTRY
  return true;
}
