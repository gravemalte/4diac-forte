#include "generated/ecetfactory.h"

${includes}

namespace EcetFactory {

AvailableEcets ecetToCreate{AvailableEcets::${default}};

void setEcetToCreate(AvailableEcets paEcet) {
  ecetToCreate = paEcet;
}

CEventChainExecutionThread *createEcet() {
#define ENTRY(name) \
  if (ecetToCreate == AvailableEcets::name) return new name();
  ${entries}
#undef ENTRY
  return nullptr;
}

}
