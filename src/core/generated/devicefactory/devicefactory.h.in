#pragma once

#include <memory>
#include <string>

#if ${multiple}
#define FORTE_MULTIPLE_DEVICES

class CDevice;

namespace DeviceFactory {
  std::unique_ptr<CDevice> createDevice(const std::string &paMGRID);
  bool setDeviceToCreate(std::string paDevice);
  std::string getAvailableDevices();
  std::string getCurrentDeviceToCreate();
};

#else

${includes}

namespace DeviceFactory {
  inline std::unique_ptr<CDevice> createDevice(const std::string &paMGRID) {
    return (paMGRID.length() != 0) ? std::make_unique<${items}>(paMGRID) : std::make_unique<${items}>();
  }
}

#endif
