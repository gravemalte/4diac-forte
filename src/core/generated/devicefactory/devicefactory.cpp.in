#include "generated/devicefactory.h"

${includes}

#ifdef FORTE_MULTIPLE_DEVICES

namespace DeviceFactory {

enum class AvailableDevices {
#define ENTRY(name) \
  name,
  ${entries}
#undef ENTRY
  len
};

AvailableDevices deviceToCreate{AvailableDevices::${default}};

bool setDeviceToCreate(std::string paDevice){
#define ENTRY(name) \
  if (paDevice == #name) deviceToCreate = AvailableDevices::name;
  ${entries}
#undef ENTRY
  return false;
}

std::string getAvailableDevices() {
  return std::string(
#define ENTRY(name) \
    " " #name
    ${entries}
#undef ENTRY
  );
}

std::string getCurrentDeviceToCreate(){
#define ENTRY(name) \
  if (deviceToCreate == AvailableDevices::name) return #name;
  ${entries}
#undef ENTRY
  return "";
}


std::unique_ptr<CDevice> createDevice(const std::string &paMGRID) {
#define ENTRY(name) \
  if (deviceToCreate == AvailableDevices::name) return (paMGRID.length() != 0) ? std::make_unique<name>(paMGRID) : std::make_unique<name>();
  ${entries}
#undef ENTRY
  return nullptr;
}

}
#endif

