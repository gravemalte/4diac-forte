#include "generated/timerhandlerfactory.h"

#include "arch/timerha.h"

${includes}

namespace TimerHandlerFactory {

  AvailableTimers timerHandlerToCreate {
    AvailableTimers::${default}
  };

  AvailableTimers getTImerHandlerName() {
    return timerHandlerToCreate;
  }

  void setTimeHandlerNameToCreate(AvailableTimers paName) {
    timerHandlerToCreate = paName;
  }

  CTimerHandler *createTimerHandler(CDeviceExecution & paDeviceExecution) {
#define ENTRY(name) \
    if (timerHandlerToCreate == AvailableTimers::name) return new name(paDeviceExecution);
    ${entries}
#undef ENTRY
    return nullptr;
  }

}
